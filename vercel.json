{
    "version": 2,
    "builds": [
        {
            "src": "whisperwind-backend/app.js",
            "use": "@vercel/node"
        },
        {
            "src": "whisperwind/public/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "whisperwind-backend/app.js"
        },
        {
            "src": "/(.*)",
            "dest": "whisperwind/public/$1"
        }
    ]
}
